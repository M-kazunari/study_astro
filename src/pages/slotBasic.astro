---
import EmbeddedHtml from "../components/EmbeddedHtml.astro";
import EmbeddedHtmlFail from "../components/EmbeddedHtmlFail.astro";

const taro = "田中太郎";
const tag = "<p>連絡が付きません。</p>";
---

<html lang="ja">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="generator" content={Astro.generator} />
        <title>Document</title>
    </head>
    <body>
        <h1>Slotの基本</h1>
        <section>
            <h2>Slotを利用しない場合</h2>
            <EmbeddedHtmlFail 
                name={taro} 
                tag={tag} />
        </section>
        <section>
            <h2>Slotを利用する場合</h2>
            <EmbeddedHtml 
                name={taro}>
                <p>連絡が付きません。</p>
            </EmbeddedHtml>
        </section>
    </body>
</html>

<style>
    section {
        border: blue 1px solid;
        margin: 10px;
    }
</style>